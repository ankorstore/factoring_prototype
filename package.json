{
  "name": "ds-prototype-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "upgrade-ds": "npm update @ankorstore/design-system",
    "deploy": "GITHUB_PAGES=true npm run build && gh-pages -d dist --dotfiles",
    "scan:sensitive": "node scripts/scan-sensitive-data.mjs",
    "sync-ds": "node scripts/sync-ds.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@ankorstore/design-system": "^28.4.0",
    "@ankorstore/vue-click-outside": "^2.0.1",
    "@splidejs/vue-splide": "^0.6.12",
    "floating-vue": "^5",
    "focus-trap": "^7.4.0",
    "vue": "^3.5.22",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vite": "^8.0.3",
    "vue-tsc": "^2.2.0"
  }
}
